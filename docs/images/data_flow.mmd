flowchart LR
    subgraph Input["输入"]
        UR[user_input]
        TT[task_type]
        SP[style_preference]
    end

    subgraph Pipeline["处理流水线"]
        R[Router] --> REQ[Requirement]
        REQ --> VS[Visual Spec]
        VS --> DOM[Domain Rules]
        DOM --> PR[Prompt]
        PR --> OUT[Asset Output]
        OUT --> EV[Evaluation]
    end

    subgraph Artifacts["产出物"]
        VS_JSON[VisualSpec JSON]
        PROMPT_TXT[Prompt Text]
        IMG[PNG / SVG]
        REPORT[EvaluationReport]
        TRACE[AgentTrace JSON]
    end

    subgraph Persist["持久化"]
        DB[(SQLite tasks)]
        FS[storage/]
    end

    UR --> R
    TT --> R
    SP --> REQ

    VS --> VS_JSON
    PR --> PROMPT_TXT
    OUT --> IMG
    EV --> REPORT
    Pipeline --> TRACE

    VS_JSON --> FS
    PROMPT_TXT --> FS
    IMG --> FS
    REPORT --> FS
    TRACE --> FS
    Pipeline --> DB
