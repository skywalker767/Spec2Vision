sequenceDiagram
    participant U as 用户
    participant API as FastAPI
    participant G as LangGraph
    participant R as TaskRouterAgent
    participant Req as RequirementAgent
    participant VS as VisualSpecAgent
    participant D as Domain Agent
    participant P as PromptAgent
    participant A as AssetManagerAgent
    participant C as CriticAgent
    participant Rev as RevisionAgent

    U->>API: POST /generate
    API->>G: WorkflowState
    G->>R: route_task
    R-->>G: task_type, route_reason
    G->>Req: parse_requirement
    Req-->>G: requirement dict
    G->>VS: build_visual_spec
    VS-->>G: VisualSpec
    G->>D: enrich_domain_spec
    D-->>G: domain_enrichment
    G->>P: build_prompt
    P-->>G: prompt / diagram spec
    G->>A: generate_asset
    A-->>G: output_path
    G->>C: evaluate_asset
    C-->>G: EvaluationReport
    alt score < 85 and enable_revision
        G->>Rev: revise_if_needed
        Rev-->>G: revised prompt
        G->>A: regenerate + re-evaluate
    end
    G->>A: save_assets
    A-->>G: prompt/report/trace paths
    G-->>API: GenerationResult
    API-->>U: JSON response
