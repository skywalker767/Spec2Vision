# VisionFlow Environment Configuration

# Application
APP_NAME=VisionFlow
APP_ENV=development
DEBUG=true
API_HOST=0.0.0.0
API_PORT=8000

# Reproducible demo (no paid API keys required)
# When true: uses mock LLM + mock image provider automatically
DEMO_MODE=false
WORKFLOW_DEBUG=false

# Database
DATABASE_URL=sqlite:///./storage/visionflow.db

# Storage paths (relative to project root)
STORAGE_ROOT=storage

# Text LLM: openai | deepseek | mock (mock used when DEMO_MODE=true)
LLM_PROVIDER=deepseek
LLM_ENABLED=true
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# Image generation: openai | mock (mock used when DEMO_MODE=true)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_IMAGE_MODEL=gpt-image-1
IMAGE_PROVIDER=openai
IMAGE_API_KEY=

OPENAI_MODEL=gpt-4o-mini

# Quality thresholds
MIN_QUALITY_SCORE=0.6
MAX_REVISION_ROUNDS=2
